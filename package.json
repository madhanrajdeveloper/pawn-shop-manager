{
  "name": "pawn-shop-manager",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:exe": "electron-builder --win"
  },
  "author": "Madhanraj J R",
  "description": "Pawn Shop Management Software",
  "repository": {
    "type": "git",
    "url": "https://github.com/madhanrajdeveloper/pawn-shop-manager.git"
  },
  "build": {
    "appId": "com.pawnshop.management",
    "productName": "Madhan Pawn Shop",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "madhanrajdeveloper",
        "repo": "pawn-shop-manager"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "publish": ["github"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "extraResources": [
      {
        "from": "backend/dist/pawnshop_api.exe",
        "to": "pawnshop_api.exe"
      }
    ],
    "files": [
      "main.js",
      {
        "from": "frontend/dist",
        "to": "dist",
        "filter": ["**/*"]
      }
    ]
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.8.3"
  }
}