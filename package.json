{
  "name": "gold-pawn-manager",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:exe": "electron-builder --win"
  },
  "author": "Madhanraj J R",
  "description": "Desktop Pawn Shop Management Software",
  "build": {
    "appId": "com.maddy10.pawnshop",
    "productName": "Gold Pawn Manager",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "extraResources": [
      {
        "from": "backend/dist/pawnshop_api.exe",
        "to": "pawnshop_api.exe"
      }
    ],
    "files": [
      "main.js",
      {
        "from": "frontend/dist",
        "to": "dist",
        "filter": ["**/*"]
      }
    ]
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.8.3"
  }
}