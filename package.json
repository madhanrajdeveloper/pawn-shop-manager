{
  "name": "pawn-shop-manager",
  "version": "2.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:exe": "electron-builder --win"
  },
  "author": "Madhanraj J R",
  "description": "Pawn Shop Management Software V2",
  "build": {
    "appId": "com.pawnshop.management",
    "productName": "Pawn Shop Management Software",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "deleteAppDataOnUninstall": true,
      "uninstallDisplayName": "Pawn Shop Management Software",
      "allowElevation": true
    },
    "extraResources": [
      {
        "from": "backend/dist/PawnShop",
        "to": "backend_server",
        "filter": ["**/*"]
      }
    ],
    "files": [
      "main.js",
      {
        "from": "frontend/dist",
        "to": "dist",
        "filter": ["**/*"]
      }
    ]
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.8.3"
  }
}